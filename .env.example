# DriveLog 마스터 환경변수 템플릿 (.env로 복사 후 값 채우기)
# drivelog-admin/client 와 drivelog-mobile 두 프로젝트가 공유합니다.
# 각 프로젝트의 vite.config.js 에서 envDir 설정으로 이 파일을 참조합니다.
#
# 사용법: cp .env.example .env  →  값 채우기

# 카카오맵 (필수)
# 카카오 개발자 콘솔(https://developers.kakao.com/)에서 앱 생성 후 발급
VITE_KAKAO_REST_KEY=
VITE_KAKAO_JS_KEY=
