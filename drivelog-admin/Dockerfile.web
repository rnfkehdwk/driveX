# ============================================================
# Stage 1: Build Admin React App
# ============================================================
FROM node:20-alpine AS build-admin

WORKDIR /app
COPY client/package*.json ./
RUN npm ci
COPY client/ .
RUN npm run build

# ============================================================
# Stage 2: Build Mobile React App
# ============================================================
FROM node:20-alpine AS build-mobile

WORKDIR /app
COPY ../drivelog-mobile/package*.json ./
RUN npm ci
COPY ../drivelog-mobile/ .
RUN npm run build

# ============================================================
# Stage 3: Nginx
# ============================================================
FROM nginx:alpine

# Admin app → /admin/
COPY --from=build-admin /app/dist /usr/share/nginx/html/admin

# Mobile app → / (root)
COPY --from=build-mobile /app/dist /usr/share/nginx/html/mobile

# Nginx config
COPY nginx/nginx.conf /etc/nginx/conf.d/default.conf

# SSL directory
RUN mkdir -p /etc/nginx/ssl

EXPOSE 80 443
CMD ["nginx", "-g", "daemon off;"]
